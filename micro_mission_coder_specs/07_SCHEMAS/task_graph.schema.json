{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TaskGraph",
  "type": "object",
  "required": [
    "tasks"
  ],
  "properties": {
    "tasks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/task"
      }
    }
  },
  "$defs": {
    "task": {
      "type": "object",
      "required": [
        "id",
        "title",
        "status",
        "depends_on",
        "acceptance_ids"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "status": {
          "enum": [
            "todo",
            "ready",
            "running",
            "blocked",
            "complete",
            "failed"
          ]
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "requirement_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "acceptance_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "allowed_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "forbidden_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "verification_commands": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "risk_flags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
